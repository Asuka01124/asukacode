{
  "compilerOptions": {
    "target": "esnext",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "strict": true,
    "esModuleInterop": true,
    "allowArbitraryExtensions": true,
    "outDir": "dist",
    "rootDir": ".",
    "declaration": true,
    "types": ["node", "bun"],
    "skipLibCheck": true
  },
  "include": ["*.ts", "*.d.ts", "core/**/*.ts", "core/**/*.d.ts"]
}
